# Environment template — copy to .env and fill in your own values.
#
#   cp .env.example .env
#
# .env is gitignored; never commit real secrets. NOTE: the app reads these from
# the process environment, not from this file (there is no python-dotenv
# dependency — the core stays zero-dependency). Load them yourself before running:
#
#   bash/zsh:     set -a; source .env; set +a
#   PowerShell:   Get-Content .env | ForEach-Object { if ($_ -match '^\s*([^#=]+)=(.*)$') { $env:$($matches[1].Trim()) = $matches[2].Trim() } }
#
# In CI, set these as repository secrets instead (Settings -> Secrets and
# variables -> Actions), not via this file.

# --- OpenAI (optional) --------------------------------------------------------
# Enables live LLM triage: run the gate with `--triage --provider openai`.
# Without it, triage falls back to the offline deterministic `fake` provider.
OPENAI_API_KEY=sk-your-key-here

# --- Turso / libSQL (optional) ------------------------------------------------
# Durable cloud flake-history so windows/trends survive between CI runs.
# When both are set, the gate uses Turso; otherwise it uses a local SQLite file.
# Get them from the Turso CLI:
#   turso db show <db> --url          -> the URL below
#   turso db tokens create <db>       -> the token below
# The token is read from the environment ONLY, never passed as a CLI argument.
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-token-here
